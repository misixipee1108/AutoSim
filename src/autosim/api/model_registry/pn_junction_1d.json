{
  "model_id": "pn_junction_1d",
  "model_name": "1D PN Junction",
  "category": "Semiconductor",
  "dimension": "1D",
  "description": "1D PN junction: Poisson, depletion approximation, or drift-diffusion with configurable doping, materials, and nonlinear solvers.",
  "parameters": [
    {"name": "model_type", "label": "Physics Model", "type": "select", "default": "poisson", "group": "Physics", "description": "Governing equations to solve.", "options": [{"value": "poisson", "label": "Nonlinear Poisson"}, {"value": "depletion", "label": "Depletion Approximation"}, {"value": "drift_diffusion", "label": "Drift-Diffusion (Gummel)"}]},
    {"name": "material", "label": "Material", "type": "select", "default": "Si", "group": "Material", "description": "Semiconductor material.", "options": [{"value": "Si", "label": "Silicon (Si)"}, {"value": "Ge", "label": "Germanium (Ge)"}]},
    {"name": "temperature_k", "label": "Temperature", "type": "number", "unit": "K", "default": 300.0, "min": 100, "max": 500, "group": "Material", "description": "Lattice temperature."},
    {"name": "doping.type", "label": "Doping Profile", "type": "select", "default": "abrupt", "group": "Doping", "description": "Junction doping distribution model.", "options": [{"value": "abrupt", "label": "Abrupt (step)"}, {"value": "linear_graded", "label": "Linear Graded"}, {"value": "gaussian", "label": "Gaussian"}, {"value": "piecewise", "label": "Piecewise / Table"}]},
    {"name": "Na", "label": "Acceptor Concentration", "type": "number", "unit": "cm⁻³", "default": 1e18, "min": 1e14, "max": 1e20, "group": "Doping", "description": "P-side acceptor concentration."},
    {"name": "Nd", "label": "Donor Concentration", "type": "number", "unit": "cm⁻³", "default": 1e16, "min": 1e14, "max": 1e20, "group": "Doping", "description": "N-side donor concentration."},
    {"name": "Lp", "label": "P-side Length", "type": "number", "unit": "cm", "default": 2e-4, "min": 1e-6, "max": 1e-2, "group": "Geometry", "description": "P-region length."},
    {"name": "Ln", "label": "N-side Length", "type": "number", "unit": "cm", "default": 2e-4, "min": 1e-6, "max": 1e-2, "group": "Geometry", "description": "N-region length."},
    {"name": "Nx", "label": "Grid Points", "type": "integer", "default": 400, "min": 20, "max": 5000, "group": "Mesh", "description": "Number of mesh nodes."},
    {"name": "junction_refinement.enabled", "label": "Junction Refinement", "type": "boolean", "default": false, "group": "Mesh", "description": "Refine mesh near the junction."},
    {"name": "junction_refinement.ratio", "label": "Refinement Ratio", "type": "number", "default": 3.0, "min": 1.1, "max": 10.0, "group": "Mesh", "description": "Junction-to-bulk cell size ratio."},
    {"name": "junction_refinement.width_frac", "label": "Junction Zone Fraction", "type": "number", "default": 0.1, "min": 0.01, "max": 0.5, "group": "Mesh", "description": "Fraction of each side refined near junction."},
    {"name": "Vapp", "label": "Applied Bias", "type": "number", "unit": "V", "default": 0.0, "min": -5, "max": 5, "group": "Bias", "description": "Applied voltage (P-side relative to N-side)."},
    {"name": "bias_scan.enabled", "label": "Enable Bias Sweep", "type": "boolean", "default": false, "group": "Bias", "description": "Sweep applied bias over a range."},
    {"name": "bias_scan.Vapp_min", "label": "Sweep Vapp Min", "type": "number", "unit": "V", "default": -1.0, "min": -5, "max": 5, "group": "Bias", "description": "Minimum sweep bias."},
    {"name": "bias_scan.Vapp_max", "label": "Sweep Vapp Max", "type": "number", "unit": "V", "default": 0.5, "min": -5, "max": 5, "group": "Bias", "description": "Maximum sweep bias."},
    {"name": "bias_scan.Vapp_step", "label": "Sweep Step", "type": "number", "unit": "V", "default": 0.1, "min": 0.01, "max": 2.0, "group": "Bias", "description": "Bias sweep step size."},
    {"name": "bias_scan.warm_start", "label": "Warm Start Between Steps", "type": "boolean", "default": true, "group": "Bias", "description": "Use previous bias ψ as initial guess."},
    {"name": "bias_scan.continuation", "label": "Bias Continuation", "type": "boolean", "default": true, "group": "Bias", "description": "Retry with halved step on convergence failure."},
    {"name": "solver.method", "label": "Nonlinear Solver", "type": "select", "default": "damped_newton", "group": "Solver", "description": "Newton iteration strategy.", "options": [{"value": "newton", "label": "Newton (full step)"}, {"value": "damped_newton", "label": "Damped Newton"}, {"value": "newton_line_search", "label": "Newton + Line Search"}]},
    {"name": "solver.linear_backend", "label": "Linear Backend", "type": "select", "default": "direct", "group": "Solver", "description": "Linear system solver.", "options": [{"value": "direct", "label": "Direct (sparse LU)"}, {"value": "iterative", "label": "Iterative"}]},
    {"name": "solver.adaptive_damping", "label": "Adaptive Damping", "type": "boolean", "default": false, "group": "Solver", "description": "Adjust damping from residual reduction rate."},
    {"name": "solver.convergence.criterion", "label": "Convergence Criterion", "type": "select", "default": "both", "group": "Solver", "description": "Require scaled residual, scaled solution step, either, or both.", "options": [{"value": "residual", "label": "Residual only"}, {"value": "solution", "label": "Solution step only"}, {"value": "either", "label": "Either criterion"}, {"value": "both", "label": "Both criteria (COMSOL-style)"}]},
    {"name": "solver.convergence.relative_tol", "label": "Relative Tolerance", "type": "number", "default": 1e-4, "min": 1e-10, "max": 1e-2, "group": "Solver", "description": "Scaled residual and solution tolerance."},
    {"name": "solver.convergence.absolute_tol", "label": "Absolute Tolerance", "type": "number", "default": null, "min": 0, "max": 1e-2, "group": "Solver", "description": "Optional absolute floor for residual and delta."},
    {"name": "solver.convergence.scaling_mode", "label": "Scaling Mode", "type": "select", "default": "auto", "group": "Solver", "description": "Reference scales for relative convergence.", "options": [{"value": "auto", "label": "Auto (initial residual / psi)"}, {"value": "initial", "label": "Initial guess"}, {"value": "manual", "label": "Manual scales"}]},
    {"name": "solver.convergence.residual_scale", "label": "Manual Residual Scale", "type": "number", "default": null, "min": 1e-20, "group": "Solver", "description": "Used when scaling_mode=manual."},
    {"name": "solver.convergence.solution_scale", "label": "Manual Solution Scale", "type": "number", "default": null, "min": 1e-20, "group": "Solver", "description": "Used when scaling_mode=manual."},
    {"name": "tol", "label": "Convergence Tolerance (legacy)", "type": "number", "default": 1e-4, "min": 1e-10, "max": 1e-2, "group": "Solver", "description": "Alias for relative_tol when solver.convergence.relative_tol is not set."},
    {"name": "max_iter", "label": "Max Iterations", "type": "integer", "default": 200, "min": 10, "max": 1000, "group": "Solver", "description": "Maximum Newton iterations."},
    {"name": "damping", "label": "Damping Factor", "type": "number", "default": 0.5, "min": 0.01, "max": 1.0, "group": "Solver", "description": "Newton damping factor."},
    {"name": "exp_clamp", "label": "Exp Clamp Limit", "type": "number", "default": 40.0, "min": 10, "max": 80, "group": "Solver", "description": "Boltzmann exponent clamp."},
    {"name": "rho_threshold_frac", "label": "Rho Threshold Fraction", "type": "number", "default": 0.05, "min": 0.001, "max": 0.5, "group": "Solver", "description": "Peak fraction for W_rho extraction."},
    {"name": "psi_threshold_frac", "label": "Psi Threshold Fraction", "type": "number", "default": 0.001, "min": 1e-5, "max": 0.2, "group": "Solver", "description": "Vbi fraction for W_psi extraction."},
    {"name": "agent.backend", "label": "Agent Backend", "type": "select", "default": "rules", "group": "Agent", "description": "Agent decision backend.", "options": [{"value": "rules", "label": "Rules Only"}, {"value": "deepseek", "label": "DeepSeek LLM"}, {"value": "hybrid", "label": "Hybrid (LLM + Rules)"}]},
    {"name": "agent.probe_window", "label": "Probe Window", "type": "integer", "default": 10, "min": 1, "max": 100, "group": "Agent", "description": "Recent probes for agent context."},
    {"name": "iteration.max_trials", "label": "Max Trials", "type": "integer", "default": 1, "min": 1, "max": 20, "group": "Agent", "description": "Maximum iteration trials."},
    {"name": "iteration.stop_on", "label": "Stop On", "type": "select", "default": "recommend_next", "group": "Agent", "description": "Iteration stop condition.", "options": [{"value": "recommend_next", "label": "Recommend Next"}, {"value": "never", "label": "Never"}]}
  ],
  "outputs": [
    {"name": "potential", "label": "Potential ψ(x)", "chart_type": "line_profile", "x": "x", "y": "psi", "unit": "V", "x_label": "x (cm)", "y_label": "ψ (V)"},
    {"name": "electric_field", "label": "Electric Field E(x)", "chart_type": "line_profile", "x": "x", "y": "E", "unit": "V/cm", "x_label": "x (cm)", "y_label": "E (V/cm)"},
    {"name": "carriers", "label": "Carrier Concentration", "chart_type": "line_profile", "x": "x", "y": "n", "unit": "cm⁻³", "x_label": "x (cm)", "y_label": "n, p (cm⁻³)"},
    {"name": "residual", "label": "Newton Residual", "chart_type": "convergence", "x": "iteration", "y": "residual_norm", "unit": "", "x_label": "Iteration", "y_label": "Residual Norm"}
  ],
  "probes": [
    {"name": "residual_norm", "label": "Residual Norm", "type": "scalar"},
    {"name": "scaled_residual_norm", "label": "Scaled Residual Norm", "type": "scalar"},
    {"name": "residual_reduction_rate", "label": "Residual Reduction Rate", "type": "scalar"},
    {"name": "delta_norm", "label": "Delta Norm", "type": "scalar"},
    {"name": "scaled_delta_norm", "label": "Scaled Delta Norm", "type": "scalar"},
    {"name": "relative_tol", "label": "Relative Tolerance", "type": "scalar"},
    {"name": "residual_scale", "label": "Residual Scale", "type": "scalar"},
    {"name": "solution_scale", "label": "Solution Scale", "type": "scalar"},
    {"name": "damping_factor", "label": "Damping Factor", "type": "scalar"},
    {"name": "max_electric_field", "label": "Max Electric Field", "type": "scalar", "unit": "V/cm"},
    {"name": "jacobian_condition_estimate", "label": "Jacobian Condition", "type": "scalar"},
    {"name": "charge_neutrality_error", "label": "Charge Neutrality Error", "type": "scalar"},
    {"name": "convergence_risk_score", "label": "Convergence Risk Score", "type": "scalar"},
    {"name": "mesh_quality_indicator", "label": "Mesh Quality", "type": "scalar"},
    {"name": "convergence_status", "label": "Convergence Status", "type": "scalar"},
    {"name": "failure_reason", "label": "Failure Reason", "type": "scalar"},
    {"name": "stalled", "label": "Stalled", "type": "boolean"},
    {"name": "is_unphysical", "label": "Unphysical", "type": "boolean"},
    {"name": "exp_clamped", "label": "Exp Clamped", "type": "boolean"}
  ],
  "tree_nodes": [
    {"id": "physics", "label": "Physics Model", "parameter_groups": ["Physics"]},
    {"id": "material", "label": "Material", "parameter_groups": ["Material"]},
    {"id": "doping", "label": "Doping", "parameter_groups": ["Doping"]},
    {"id": "geometry", "label": "Geometry", "parameter_groups": ["Geometry"]},
    {"id": "mesh", "label": "Mesh", "parameter_groups": ["Mesh"]},
    {"id": "bias", "label": "Bias", "parameter_groups": ["Bias"]},
    {"id": "solver", "label": "Solver", "parameter_groups": ["Solver"]},
    {"id": "agent", "label": "Agent Settings", "parameter_groups": ["Agent"]}
  ],
  "default_charts": [
    {"id": "overview", "label": "Overview", "chart_type": "overview"},
    {"id": "profiles", "label": "Profiles", "chart_type": "profiles", "series_names": ["potential", "electric_field"]},
    {"id": "carriers", "label": "Carriers", "chart_type": "profiles", "series_names": ["electron_density", "hole_density", "charge_density"]},
    {"id": "convergence", "label": "Newton Convergence", "chart_type": "convergence", "series_names": ["scaled_residual", "scaled_delta"]},
    {"id": "sweep", "label": "Bias Sweep", "chart_type": "sweep", "series_names": ["W_vs_Vapp", "Cj_vs_Vapp"]}
  ],
  "default_config": {
    "model_type": "poisson",
    "material": "Si",
    "temperature_k": 300.0,
    "doping": {"type": "abrupt"},
    "Na": 1e18,
    "Nd": 1e16,
    "Lp": 2e-4,
    "Ln": 2e-4,
    "Nx": 400,
    "Vapp": 0.0,
    "tol": 1e-4,
    "max_iter": 200,
    "damping": 0.5,
    "exp_clamp": 40.0,
    "rho_threshold_frac": 0.05,
    "psi_threshold_frac": 0.001,
    "solver": {"method": "damped_newton", "linear_backend": "direct", "adaptive_damping": false, "convergence": {"criterion": "both", "relative_tol": 1e-4, "scaling_mode": "auto"}},
    "junction_refinement": {"enabled": false, "ratio": 3.0, "width_frac": 0.1},
    "bias_scan": {"enabled": false, "Vapp_min": -1.0, "Vapp_max": 0.5, "Vapp_step": 0.1, "warm_start": true, "continuation": true},
    "optimization": {"enabled": false, "method": "random", "max_trials": 20, "design_vars": [], "objectives": []},
    "agent": {"backend": "rules", "probe_window": 10},
    "iteration": {"max_trials": 1, "stop_on": "recommend_next"}
  }
}
