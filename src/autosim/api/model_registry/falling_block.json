{
  "model_id": "falling_block",
  "model_name": "Falling Block with Drag",
  "category": "Mechanics",
  "dimension": "0D",
  "description": "1D vertical free fall with configurable air drag (linear, quadratic, polynomial, custom).",
  "parameters": [
    {"name": "mass", "label": "Mass", "type": "number", "unit": "kg", "default": 1.0, "min": 0.01, "max": 1000, "group": "Body", "description": "Block mass."},
    {"name": "gravity", "label": "Gravity", "type": "number", "unit": "m/s²", "default": 9.81, "min": 0.1, "max": 50, "group": "Body", "description": "Gravitational acceleration."},
    {"name": "y0", "label": "Initial Height", "type": "number", "unit": "m", "default": 100.0, "min": 0.1, "max": 10000, "group": "Body", "description": "Initial vertical position."},
    {"name": "v0", "label": "Initial Velocity", "type": "number", "unit": "m/s", "default": 0.0, "min": -500, "max": 500, "group": "Body", "description": "Initial vertical velocity."},
    {"name": "ground_y", "label": "Ground Level", "type": "number", "unit": "m", "default": 0.0, "min": -1000, "max": 1000, "group": "Body", "description": "Ground contact height."},
    {"name": "drag_model", "label": "Drag Model", "type": "select", "default": "quadratic", "group": "Drag", "description": "Drag force model.", "options": [{"value": "linear", "label": "Linear"}, {"value": "quadratic", "label": "Quadratic"}, {"value": "polynomial", "label": "Polynomial"}, {"value": "custom", "label": "Custom Expression"}]},
    {"name": "drag_params.c2", "label": "Quadratic Coefficient c2", "type": "number", "unit": "kg/m", "default": 0.5, "min": 0, "max": 10, "group": "Drag", "description": "Quadratic drag coefficient."},
    {"name": "drag_params.c1", "label": "Linear Coefficient c1", "type": "number", "unit": "kg/s", "default": 0.1, "min": 0, "max": 10, "group": "Drag", "description": "Linear drag coefficient."},
    {"name": "t_max", "label": "Max Time", "type": "number", "unit": "s", "default": 30.0, "min": 0.1, "max": 600, "group": "Integration", "description": "Maximum simulation time."},
    {"name": "probe_interval", "label": "Probe Interval", "type": "number", "unit": "s", "default": 0.1, "min": 0.001, "max": 10, "group": "Integration", "description": "Time between probe snapshots."},
    {"name": "dt", "label": "Time Step", "type": "number", "unit": "s", "default": 0.01, "min": 0.0001, "max": 1, "group": "Integration", "description": "RK4 integration step size."},
    {"name": "agent.backend", "label": "Agent Backend", "type": "select", "default": "rules", "group": "Agent", "description": "Agent decision backend.", "options": [{"value": "rules", "label": "Rules Only"}, {"value": "deepseek", "label": "DeepSeek LLM"}, {"value": "hybrid", "label": "Hybrid (LLM + Rules)"}]},
    {"name": "iteration.max_trials", "label": "Max Trials", "type": "integer", "default": 1, "min": 1, "max": 20, "group": "Agent", "description": "Maximum iteration trials."}
  ],
  "outputs": [
    {"name": "position", "label": "Position", "chart_type": "time_series", "x": "t", "y": "y", "unit": "m", "x_label": "Time (s)", "y_label": "Height (m)"},
    {"name": "velocity", "label": "Velocity", "chart_type": "time_series", "x": "t", "y": "v", "unit": "m/s", "x_label": "Time (s)", "y_label": "Velocity (m/s)"},
    {"name": "energy_drift", "label": "Energy Drift", "chart_type": "convergence", "x": "t", "y": "energy_drift", "unit": "J", "x_label": "Time (s)", "y_label": "Energy Drift (J)"}
  ],
  "probes": [
    {"name": "energy_drift", "label": "Energy Drift", "type": "scalar", "unit": "J"},
    {"name": "drag_force", "label": "Drag Force", "type": "scalar", "unit": "N"},
    {"name": "is_diverging", "label": "Diverging", "type": "boolean"},
    {"name": "is_nan", "label": "NaN Detected", "type": "boolean"},
    {"name": "distance_to_ground", "label": "Distance to Ground", "type": "scalar", "unit": "m"}
  ],
  "tree_nodes": [
    {"id": "body", "label": "Body Parameters", "parameter_groups": ["Body"]},
    {"id": "drag", "label": "Drag Model", "parameter_groups": ["Drag"]},
    {"id": "integration", "label": "Integration", "parameter_groups": ["Integration"]},
    {"id": "agent", "label": "Agent Settings", "parameter_groups": ["Agent"]}
  ],
  "default_charts": [
    {"id": "overview", "label": "Overview", "chart_type": "overview"},
    {"id": "trajectory", "label": "Trajectory", "chart_type": "time_series", "series_names": ["position", "velocity"]},
    {"id": "convergence", "label": "Energy Drift", "chart_type": "convergence", "series_names": ["energy_drift"]}
  ],
  "default_config": {
    "mass": 1.0,
    "gravity": 9.81,
    "y0": 100.0,
    "v0": 0.0,
    "ground_y": 0.0,
    "drag_model": "quadratic",
    "drag_params": {"c2": 0.5},
    "t_max": 30.0,
    "probe_interval": 0.1,
    "dt": 0.01,
    "agent": {"backend": "rules", "probe_window": 10},
    "iteration": {"max_trials": 1, "stop_on": "recommend_next"}
  }
}
